# trader-bot configuration. Copy to `.env` and edit. `.env` is gitignored.
# Precedence: CLI flag > shell env var > .env file > hardcoded default.

# TCP address the mt5-bridge tick stream listener binds to.
# Per the architecture doc, services should bind localhost only.
MT5_ADDR=127.0.0.1:5000

# HTTP base URL of the MT5 gateway (applications/mt5-remote/gateway.py).
# NOT the rpyc port (18812) — the gateway listens on 18813 by default.
MT5_BASE_URL=http://localhost:18812

# Log handler: "text" (human-readable) or "json" (structured).
LOG_FORMAT=text

# deepseek's API key for the /v1/ai/ endpoint. Required if using the "deepseek" AI provider.
DEEPSEEK_API_KEY=sk-*****

# Postgres connection string for storing AI logs. Format: postgres://user:password@host:port/dbname
DB_CONN=postgres://postgres:password@localhost:5432/trader_bot_db